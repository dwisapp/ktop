<?xml version="1.0" encoding="utf-8"?>
<odoo>

    

    <record id="delivery_note_view_form_inherit" model="ir.ui.view">
        <field name="name">delivery.note.view.form.inherit</field>
        <field name="model">delivery.note</field>
        <field name="inherit_id" ref="fjr_pgp_sale.delivery_note_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_uang_jalan" string="Uang Jalan" type="object" class="oe_stat_button" icon="fa-book" invisible="uang_jalan_count == 0">
                    <field name="uang_jalan_count" widget="statinfo" string="Uang Jalan" />
                </button>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_create_uang_jalan" string="Create Uang Jalan" type="object" class="oe_highlight" invisible="state == 'cancel'"/>
            </xpath>
        </field>
    </record>


</odoo>
