<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="uang_jalan_driver_claim_action" model="ir.actions.act_window">
        <field name="name">Driver Claim</field>
        <field name="res_model">uang.jalan.driver.claim</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>

    </record>

    <record id="uang_jalan_driver_claim_view_tree" model="ir.ui.view">
        <field name="name">uang.jalan.driver.claim.view.tree</field>
        <field name="model">uang.jalan.driver.claim</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="name" optional="show" />
                <field name="driver_id" optional="show" />
                <field name="date" optional="show" />
                <field name="amount" optional="show" />
                <field name="total_potongan" optional="show" />
                <field name="state" widget="badge" decoration-danger="state == 'cancel'" decoration-success="state == 'done'" decoration-info="state == 'confirm'" optional="show" />
            </tree>
        </field>
    </record>

    <record id="uang_jalan_driver_claim_view_form" model="ir.ui.view">
        <field name="name">uang.jalan.driver.claim.view.form</field>
        <field name="model">uang.jalan.driver.claim</field>
        <field name="arch" type="xml">
            <form string="">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" invisible="state != 'draft'"  class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state == 'cancel'" class="btn-danger"/>
                    <button name="action_draft" type="object" string="Reset to Draft" invisible="state != 'cancel'"  class="btn-secondary"/>
                    <field name="state" widget="statusbar"  class="oe_inline"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="driver_id" options="{'no_create': True}"  domain="[('is_driver', '=', True)]" readonly="state != 'draft'" />
                            <field name="date" readonly="state != 'draft'" />
                            <field name="amount" readonly="state != 'draft'" />
                            <field name="persentase_potongan" readonly="state != 'draft'" />
                        </group>
                        <group>
                            <field name="keterangan" />
                            <field name="total_potongan" />
                        </group>
                    </group>
                    <notebook>
                        <page name="uang_jalan" string="Uang Jalan">
                            <field name="uang_jalan_ids"  options="{'no_create': True}" readonly="1">
                                <tree editable="bottom">
                                    <field name="name"  />
                                    <field name="date" />
                                    <field name="potongan_claim" />
                                </tree>
                            </field>
                            
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" options="{'no_create': True}"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <menuitem
        id="uang_jalan_driver_claim_menu"
        name="Driver Claim"
        action="uang_jalan_driver_claim_action"
        parent="fjr_kasir_uang_jalan.uang_jalan_main_menu"
        sequence="20"/>

</odoo>
