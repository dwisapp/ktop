<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.module.category" id="module_category_fleet_document">
        <field name="name">Fleet Document</field>
        <field name="description">Fleet Document</field>
        <field name="sequence">15</field>
        <field name="parent_id" eval="False"/>
    </record>

    <record id="group_fleet_document_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_fleet_document"/>
    </record>

    <record id="group_fleet_document_manager" model="res.groups">
        <field name="name">Document Manager</field>
        <field name="category_id" ref="module_category_fleet_document"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('group_fleet_document_user'))]"/>
    </record>

    <record id="group_fleet_document_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_fleet_document"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="implied_ids" eval="[(4, ref('group_fleet_document_manager'))]"/>
    </record>


    



</odoo>
