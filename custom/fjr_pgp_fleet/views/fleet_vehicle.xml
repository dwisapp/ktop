<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fleet_vehicle_view_form_inherit" model="ir.ui.view">
        <field name="name">fleet.vehicle.view.form.inherit</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_open_fleet_document"  type="object" class="oe_stat_button" icon="fa-folder-open-o">
                    <field name="fleet_document_count" widget="statinfo" string="Documents"/>
                </button>
                <button name="action_open_fleet_stock_usage" string="Item Usage"  type="object" class="oe_stat_button" icon="fa-cog" />
            </div>
            <page name="page_model" position="after">
                <page name="document" string="Document">
                    <group>
                    
                        <group>
                            <field name="jatuh_tempo_pajak_tahunan"/>
                            <field name="jatuh_tempo_pajak_5_tahunan" />
                            <field name="no_lambung" />
                        </group>
                        <group>
                            <field name="no_kir_kepala" />
                            <field name="masa_berlaku_kir_kepala" />
                            <field name="nomer_kir_buntut" />
                            <field name="masa_berlaku_kir_buntut" />
                        </group>
                    </group>
                    <!-- <notebook>
                        <page name="Document" string="Document">
                            <field name="fleet_document_ids">
                                <tree editable="bottom">

                                </tree>
                            </field>
                        </page>
                    </notebook> -->
                </page>
            </page>
        </field>
    </record>
    

</odoo>
