<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fleet_item_usage_action" model="ir.actions.act_window">
        <field name="name">Item Usage</field>
        <field name="res_model">fleet.item.usage</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            ('usage_type', '=', 'usage')
        ]</field>
        <field name="context">{
            'default_usage_type': 'usage'
        }</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new item usage.
            </p>
        </field>
    </record>

    <record id="fleet_item_loan_action" model="ir.actions.act_window">
        <field name="name">Item Loan</field>
        <field name="res_model">fleet.item.usage</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[
            ('usage_type', '=', 'loan')
        ]</field>
        <field name="context">{
            'default_usage_type': 'loan'
        }</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new item usage.
            </p>
        </field>
    </record>

    <record id="fleet_item_usage_view_tree" model="ir.ui.view">
        <field name="name">fleet.item.usage.view.tree</field>
        <field name="model">fleet.item.usage</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="name" />
                <field name="date" />
                <field name='state' widget="badge" decoration-danger="state == 'cancel'" decoration-success="state in ('return', 'used')" decoration-warning="state in ('in_loan')" />
                <field name='description' />
            </tree>
        </field>
    </record>

    <record id="fleet_item_usage_view_form" model="ir.ui.view">
        <field name="name">fleet.item.usage.view.form</field>
        <field name="model">fleet.item.usage</field>
        <field name="arch" type="xml">
            <form string="">
                <field name="usage_type" invisible="1"  />
                <field name="display_button_return" invisible="1" />
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_return" string="Return" type="object" class="oe_highlight"  invisible="not display_button_return" />
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancel'" confirm="Are you sure you want to cancel this item usage?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_loan,used" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date" readonly="state != 'draft'" />
                            <field name="company_id" invisible="1" groups="!base.group_multi_company" readonly="state != 'draft'" />
                            <field name="company_id"  groups="base.group_multi_company" readonly="state != 'draft'" />
                            <field name="location_id" options="{'no_create':True}" readonly="state != 'draft'" />
                            <field name="location_dest_id" invisible="1" readonly="state != 'draft'" />
                        </group>
                        <group>
                            <field name="fleet_id" readonly="state != 'draft'" />
                            <field name="description" readonly="state != 'draft'" />
                        </group>
                    </group>
                    <notebook>
                        <page name="usage_move_ids" string="Usage Items">
                            <field name="usage_move_ids" widget="stock_move_one2many" readonly="state != 'draft'"  context="{'default_company_id': company_id, 'default_date': date, 'default_date_deadline': date, 'picking_type_code': 'internal', 'form_view_ref': 'stock.view_stock_move_operations',  'default_location_id': location_id, 'default_location_dest_id': location_dest_id}">
                                <tree decoration-muted="scrapped == True or state == 'cancel'" string="Stock Moves" editable="1">
                                    <field name="company_id" column_invisible="True"/>
                                    <field name="name" column_invisible="True"/>
                                    <field name="state" readonly="0" column_invisible="True"/>
                                    <field name="picking_type_id" column_invisible="True"/>
                                    <field name="move_line_ids" column_invisible="True"/>
                                    <field name="location_id" column_invisible="True"/>
                                    <field name="location_dest_id" column_invisible="True"/>
                                    <field name="partner_id" column_invisible="True" readonly="state == 'done'"/>
                                    <field name="scrapped" column_invisible="True"/>
                                    <field name="picking_code" column_invisible="True"/>
                                    <field name="product_type" column_invisible="True"/>
                                    <field name="show_details_visible" column_invisible="True"/>
                                    <field name="show_reserved" column_invisible="True"/>
                                    <field name="additional" column_invisible="True"/>
                                    <field name="move_lines_count" column_invisible="True"/>
                                    <field name="is_locked" column_invisible="True"/>
                                    <field name="product_uom_category_id" column_invisible="True"/>
                                    <field name="has_tracking" column_invisible="True"/>
                                    <field name="display_assign_serial" column_invisible="True"/>
                                    <field name="product_id" column_invisible="parent.usage_type != 'usage'" domain="[('type', 'in', ['product', 'consu']), ('fleet_usage','=',True)]" context="{'default_detailed_type': 'product', 'default_fleet_usage_loan':True, 'default_fleet_usage': True}" required="1" readonly="(state != 'draft' and not additional) or move_lines_count &gt; 0" force_save="1"/>
                                    <field name="product_id" column_invisible="parent.usage_type == 'usage'"  domain="[('type', 'in', ['product', 'consu']), ('fleet_usage_loan','=',True)]" context="{'default_detailed_type': 'product', 'default_fleet_usage_loan':True, 'default_fleet_usage': True}" required="1" readonly="(state != 'draft' and not additional) or move_lines_count &gt; 0" force_save="1"/>
                                    <field name="description_picking" string="Description" optional="hide"/>
                                    <field name="date" optional="hide"/>
                                    <field name="date_deadline" optional="hide"/>
                                    <field name="is_quantity_done_editable" column_invisible="True"/>
                                    <field name="show_quant" column_invisible="True"/>
                                    <field name="show_lots_text" column_invisible="True"/>
                                    <field name="show_lots_m2o" column_invisible="True"/>
                                    <field name="display_assign_serial" column_invisible="True"/>
                                    <field name="is_initial_demand_editable" column_invisible="True"/>
                                    <field name="display_import_lot" column_invisible="True"/>
                                    <field name="picking_type_entire_packs" column_invisible="True"/>
                                    <field name="product_packaging_id" groups="product.group_stock_packaging" context="{'default_product_id': product_id}" readonly="not product_id"/>
                                    <field name="product_uom_qty" string="Demand" readonly="not is_initial_demand_editable"/>
                                    <field name="forecast_expected_date" column_invisible="True"/>
                                    <field name="forecast_availability" string="Forecast" optional="hide" column_invisible="parent.state in ('draft', 'done') " widget="forecast_widget"/>
                                    <field name="product_qty" readonly="1" column_invisible="True"/>
                                    <field name="quantity" string="Quantity" readonly="not is_quantity_done_editable" column_invisible="1" decoration-danger="product_uom_qty and quantity &gt; product_uom_qty and parent.state not in ['done', 'cancel']"/>
                                    <field name="returned_qty" string="Returned Quantity" readonly="not is_quantity_done_editable" column_invisible="parent.state == 'draft'" decoration-danger="product_uom_qty and quantity &gt; product_uom_qty and parent.state not in ['done', 'cancel']"/>
                                    <field name="product_uom" readonly="state != 'draft' and not additional" options="{'no_open': True, 'no_create': True}" string="Unit" groups="uom.group_uom"/>
                                    <field name="product_uom" groups="!uom.group_uom" column_invisible="True"/>
                                    <field name="picked" optional="hide" column_invisible="parent.state=='draft'"/>
                                    <field name="lot_ids" widget="many2many_tags" column_invisible="parent.state == 'draft'" groups="stock.group_production_lot" invisible="not show_details_visible or has_tracking != 'serial'" optional="hide" options="{'create': [('parent.use_create_lots', '=', True)]}" context="{'default_company_id': company_id, 'default_product_id': product_id, 'active_picking_id': parent.id}" domain="[('product_id','=',product_id)]"/>
                                    <button name="action_assign_serial" type="object" icon="fa-plus-square" role="img" title="Assign Serial Numbers" invisible="not display_assign_serial"/>
                                    <button type="object" name="action_product_forecast_report" title="Forecast Report" icon="fa-area-chart" invisible="quantity == 0 and forecast_availability &lt;= 0 "/>
                                    <button type="object" name="action_product_forecast_report" title="Forecast Report" icon="fa-area-chart text-danger" invisible="quantity &gt; 0 or forecast_availability &gt; 0 "/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

</odoo>
