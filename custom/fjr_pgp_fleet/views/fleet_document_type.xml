<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fleet_document_type_action" model="ir.actions.act_window">
        <field name="name">Document Type</field>
        <field name="res_model">fleet.document.type</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create new document type
            </p>
        </field>
    </record>

    <record id="document_type_view_tree" model="ir.ui.view">
        <field name="name">fleet.document.view.tree</field>
        <field name="model">fleet.document</field>
        <field name="arch" type="xml">
            <tree string="" editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

</odoo>
