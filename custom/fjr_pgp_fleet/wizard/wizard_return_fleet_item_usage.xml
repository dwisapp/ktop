<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_return_fleet_item_usage_view_form" model="ir.ui.view">
        <field name="name">wizard.return.fleet.item.usage.view.form</field>
        <field name="model">wizard.return.fleet.item.usage</field>
        <field name="arch" type="xml">
            <form string="">
                <notebook>
                    <page name="line_ids" string="Item to Return">
                        <field name="line_ids">
                            <tree editable='bottom' create="0" delete="0">
                                <field name="product_id" readonly="1" force_save="1"/>
                                <field name="quantity_used" readonly="1" force_save="1"/>
                                <field name="quantity_return" required="1"/>
                                <field name="origin_move_id" column_invisible="1"/>
                            </tree>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button name="action_return" string="Return" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
