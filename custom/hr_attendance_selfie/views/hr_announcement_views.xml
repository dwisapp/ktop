<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_hr_announcement_tree" model="ir.ui.view">
        <field name="name">hr.announcement.tree</field>
        <field name="model">hr.announcement</field>
        <field name="arch" type="xml">
            <tree string="Announcements" decoration-info="state=='draft'" decoration-success="state=='published'" decoration-muted="state=='archived'">
                <field name="is_pinned" widget="boolean_toggle"/>
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge" decoration-info="state=='draft'" decoration-success="state=='published'" decoration-muted="state=='archived'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hr_announcement_form" model="ir.ui.view">
        <field name="name">hr.announcement.form</field>
        <field name="model">hr.announcement</field>
        <field name="arch" type="xml">
            <form string="Announcement">
                <header>
                    <button name="action_publish" string="Publish" type="object" states="draft" class="oe_highlight"/>
                    <button name="action_archive" string="Archive" type="object" states="published"/>
                    <button name="action_draft" string="Set to Draft" type="object" states="archived,published"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object" class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button" options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Pinned" bg_color="bg-info" attrs="{'invisible': [('is_pinned', '=', False)]}"/>
                    <group>
                        <group>
                            <field name="name" placeholder="Announcement Title"/>
                            <field name="priority" widget="priority"/>
                            <field name="is_pinned"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Content">
                            <field name="description" widget="html"/>
                        </page>
                        <page string="Target Audience">
                            <group>
                                <field name="department_ids" widget="many2many_tags"/>
                                <field name="employee_ids" widget="many2many_tags"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                <p><strong>Note:</strong> If no departments or employees are selected, this announcement will be visible to all employees.</p>
                            </div>
                        </page>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_hr_announcement_kanban" model="ir.ui.view">
        <field name="name">hr.announcement.kanban</field>
        <field name="model">hr.announcement</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="is_pinned"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="is_pinned" widget="boolean_favorite" nolabel="1"/>
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <field name="priority" widget="priority"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="description" widget="html"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span><i class="fa fa-calendar"/> <field name="date_from"/> - <field name="date_to"/></span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'published': 'success', 'archived': 'muted'}}"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_hr_announcement_search" model="ir.ui.view">
        <field name="name">hr.announcement.search</field>
        <field name="model">hr.announcement</field>
        <field name="arch" type="xml">
            <search string="Announcements">
                <field name="name"/>
                <field name="description"/>
                <filter string="Pinned" name="pinned" domain="[('is_pinned', '=', True)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Published" name="published" domain="[('state', '=', 'published')]"/>
                <filter string="Archived" name="archived" domain="[('state', '=', 'archived')]"/>
                <separator/>
                <filter string="Active Today" name="active_today" domain="[('date_from', '&lt;=', context_today().strftime('%Y-%m-%d')), '|', ('date_to', '=', False), ('date_to', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Start Date" name="group_date_from" context="{'group_by': 'date_from'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_announcement" model="ir.actions.act_window">
        <field name="name">Announcements</field>
        <field name="res_model">hr.announcement</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="context">{'search_default_published': 1, 'search_default_active_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first announcement
            </p>
            <p>
                Announcements are displayed in the mobile app for employees to stay informed.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_hr_announcement"
              name="Announcements"
              parent="hr.menu_hr_root"
              action="action_hr_announcement"
              sequence="100"/>
</odoo>
