<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== MAIN ATTENDANCE PORTAL PAGE ==================== -->

    <template id="portal_attendance_page" name="My Attendance Portal">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">My Attendance</t>
            </t>

            <div class="container mt-4 mb-5">
                <div class="row">
                    <div class="col-12">

                        <!-- Page Header -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-body">
                                <div class="d-flex align-items-center">
                                    <div class="flex-grow-1">
                                        <h3 class="mb-1">
                                            <i class="fa fa-clock-o text-primary"/> Attendance Check-In
                                        </h3>
                                        <p class="text-muted mb-0">
                                            Welcome, <strong t-esc="employee.name"/>!
                                        </p>
                                    </div>
                                    <div class="text-end">
                                        <t t-if="attendance_state == 'checked_in'">
                                            <span class="badge bg-success" style="font-size: 1rem; padding: 0.5rem 1rem;">
                                                <i class="fa fa-check-circle"/> Checked In
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge bg-secondary" style="font-size: 1rem; padding: 0.5rem 1rem;">
                                                <i class="fa fa-circle-o"/> Checked Out
                                            </span>
                                        </t>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Last Attendance Info -->
                        <t t-if="last_attendance">
                            <div class="alert alert-info mb-4">
                                <i class="fa fa-info-circle"/>
                                Last activity:
                                <strong>
                                    <t t-if="last_attendance.check_out">
                                        Checked out at <span t-esc="last_attendance.check_out" t-options='{"widget": "datetime"}'/>
                                    </t>
                                    <t t-else="">
                                        Checked in at <span t-esc="last_attendance.check_in" t-options='{"widget": "datetime"}'/>
                                    </t>
                                </strong>
                            </div>
                        </t>

                        <!-- Main Camera Card -->
                        <div class="card border-0 shadow-sm mb-4">
                            <div class="card-header bg-primary text-white">
                                <h5 class="mb-0">
                                    <i class="fa fa-camera"/>
                                    <t t-if="attendance_state == 'checked_out'">
                                        Take Selfie to Check-In
                                    </t>
                                    <t t-else="">
                                        Take Selfie to Check-Out
                                    </t>
                                </h5>
                            </div>
                            <div class="card-body">

                                <!-- GPS Status -->
                                <div class="alert alert-light mb-3" id="gps-status-container">
                                    <i class="fa fa-map-marker text-primary"/>
                                    <span id="gps-status-text">Detecting GPS location...</span>
                                </div>

                                <!-- Camera Preview Area -->
                                <div class="text-center mb-3">
                                    <div class="camera-preview-wrapper" style="max-width: 500px; margin: 0 auto;">
                                        <!-- Video Preview -->
                                        <video
                                            id="camera-video"
                                            autoplay="autoplay"
                                            playsinline="playsinline"
                                            class="rounded border"
                                            style="width: 100%; height: auto; display: block;"/>

                                        <!-- Canvas for capture (hidden) -->
                                        <canvas id="photo-canvas" style="display: none;"/>

                                        <!-- Photo Preview (after capture) -->
                                        <img
                                            id="photo-preview"
                                            class="rounded border"
                                            style="width: 100%; height: auto; display: none;"
                                            alt="Captured Photo"/>

                                        <!-- Loading State -->
                                        <div id="camera-loading" class="py-5">
                                            <i class="fa fa-spinner fa-spin fa-3x text-primary"/>
                                            <p class="mt-3 text-muted">Starting camera...</p>
                                        </div>
                                    </div>
                                </div>

                                <!-- Action Buttons -->
                                <div class="text-center">
                                    <div class="btn-group btn-group-lg" role="group">
                                        <!-- Capture Button -->
                                        <button
                                            id="btn-capture-photo"
                                            class="btn btn-primary"
                                            style="display: none;">
                                            <i class="fa fa-camera"/> Capture Photo
                                        </button>

                                        <!-- Retake Button -->
                                        <button
                                            id="btn-retake-photo"
                                            class="btn btn-warning"
                                            style="display: none;">
                                            <i class="fa fa-refresh"/> Retake
                                        </button>

                                        <!-- Check-In Button -->
                                        <button
                                            id="btn-submit-checkin"
                                            class="btn btn-success btn-lg"
                                            style="display: none;"
                                            t-if="attendance_state == 'checked_out'">
                                            <i class="fa fa-sign-in"/> Submit Check-In
                                        </button>

                                        <!-- Check-Out Button -->
                                        <button
                                            id="btn-submit-checkout"
                                            class="btn btn-danger btn-lg"
                                            style="display: none;"
                                            t-if="attendance_state == 'checked_in'">
                                            <i class="fa fa-sign-out"/> Submit Check-Out
                                        </button>
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Today's Attendance Records -->
                        <t t-if="today_attendances">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fa fa-list"/> Today's Attendance
                                    </h5>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Check-In</th>
                                                    <th>Check-Out</th>
                                                    <th>Hours Worked</th>
                                                    <th class="text-center">Photos</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <t t-foreach="today_attendances" t-as="att">
                                                    <tr>
                                                        <td>
                                                            <span t-esc="att.check_in" t-options='{"widget": "datetime"}'/>
                                                        </td>
                                                        <td>
                                                            <t t-if="att.check_out">
                                                                <span t-esc="att.check_out" t-options='{"widget": "datetime"}'/>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="badge bg-warning">In Progress</span>
                                                            </t>
                                                        </td>
                                                        <td>
                                                            <t t-if="att.worked_hours">
                                                                <strong><span t-esc="'%.2f' % att.worked_hours"/> hrs</strong>
                                                            </t>
                                                            <t t-else="">-</t>
                                                        </td>
                                                        <td class="text-center">
                                                            <t t-if="att.check_in_image">
                                                                <i class="fa fa-camera text-success" title="Check-in photo available"/>
                                                            </t>
                                                            <t t-if="att.check_out_image">
                                                                <i class="fa fa-camera text-danger ms-2" title="Check-out photo available"/>
                                                            </t>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- View History Link -->
                        <div class="text-center mt-4">
                            <a href="/my/attendance/history" class="btn btn-outline-primary">
                                <i class="fa fa-history"/> View Full History
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ==================== NO EMPLOYEE ERROR PAGE ==================== -->

    <template id="portal_no_employee" name="No Employee Error">
        <t t-call="portal.portal_layout">
            <div class="container mt-5">
                <div class="alert alert-danger text-center">
                    <i class="fa fa-exclamation-triangle fa-3x mb-3"/>
                    <h4>No Employee Record Found</h4>
                    <p>Your user account is not linked to an employee record.</p>
                    <p>Please contact your HR administrator to link your account.</p>
                </div>
            </div>
        </t>
    </template>

    <!-- ==================== ATTENDANCE HISTORY PAGE ==================== -->

    <template id="portal_attendance_history" name="Attendance History">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Attendance History</t>
            </t>

            <div class="container mt-4 mb-5">
                <div class="row">
                    <div class="col-12">

                        <div class="card border-0 shadow-sm">
                            <div class="card-header bg-primary text-white">
                                <h4 class="mb-0">
                                    <i class="fa fa-history"/> Attendance History (Last 30 Days)
                                </h4>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Date</th>
                                                <th>Check-In</th>
                                                <th>Check-Out</th>
                                                <th>Hours Worked</th>
                                                <th class="text-center">Location</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="attendances">
                                                <t t-foreach="attendances" t-as="att">
                                                    <tr>
                                                        <td>
                                                            <strong>
                                                                <span t-esc="att.check_in" t-options='{"widget": "date"}'/>
                                                            </strong>
                                                        </td>
                                                        <td>
                                                            <span t-esc="att.check_in" t-options='{"widget": "time"}'/>
                                                        </td>
                                                        <td>
                                                            <t t-if="att.check_out">
                                                                <span t-esc="att.check_out" t-options='{"widget": "time"}'/>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="badge bg-warning">In Progress</span>
                                                            </t>
                                                        </td>
                                                        <td>
                                                            <t t-if="att.worked_hours">
                                                                <strong><span t-esc="'%.2f' % att.worked_hours"/> hrs</strong>
                                                            </t>
                                                            <t t-else="">-</t>
                                                        </td>
                                                        <td class="text-center">
                                                            <t t-if="att.in_latitude and att.in_longitude">
                                                                <a t-attf-href="https://www.google.com/maps?q={{att.in_latitude}},{{att.in_longitude}}"
                                                                   target="_blank"
                                                                   class="btn btn-sm btn-outline-primary">
                                                                    <i class="fa fa-map-marker"/> View
                                                                </a>
                                                            </t>
                                                            <t t-else="">-</t>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                            <t t-else="">
                                                <tr>
                                                    <td colspan="5" class="text-center text-muted py-5">
                                                        <i class="fa fa-inbox fa-3x mb-3 d-block"/>
                                                        No attendance records found.
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <a href="/my/attendance" class="btn btn-primary">
                                <i class="fa fa-arrow-left"/> Back to Check-In
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
