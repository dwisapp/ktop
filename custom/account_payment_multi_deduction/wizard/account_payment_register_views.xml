<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_register_form" model="ir.ui.view">
        <field name="name">account.payment.register.form</field>
        <field name="model">account.payment.register</field>
        <field name="inherit_id" ref="account.view_account_payment_register_form"/>
        <field name="arch" type="xml">
            <field name="payment_date" position="after">
                <field name="tax_ids" widget="many2many_tags" options="{'no_create': True}" domain="[('type_tax_use', '=', 'sale'), ('company_id', '=', company_id), ('tax_exigibility','=','on_payment')]" invisible="payment_type == 'outbound' or (not can_edit_wizard or can_group_payments and not group_payment)"/>
                <field name="tax_ids" widget="many2many_tags" options="{'no_create': True}" domain="[('type_tax_use', '=', 'purchase'), ('company_id', '=', company_id), ('tax_exigibility','=','on_payment')]" invisible="payment_type == 'inbound' or (not can_edit_wizard or can_group_payments and not group_payment)"/>

                <field name="payment_register_deduction_id"/>
                <field name="payment_deduction_amount" />
            </field>
            <xpath expr="//field[@name='writeoff_account_id']" position="after">
                <div groups="analytic.group_analytic_accounting" invisible="payment_difference_handling != 'reconcile'">
                    <label class="oe_edit_only" for="analytic_distribution"/>
                    <field groups="analytic.group_analytic_accounting" name="analytic_distribution" options="{'product_field': 'product_id', 'account_field': 'account_id', 'business_domain': 'expense'}" widget="analytic_distribution"/>
                </div>
            </xpath>
            <xpath expr="/form/group/group[@name='group3']/div/div" position="attributes">
                <attribute name="invisible">payment_difference_handling != 'reconcile'</attribute>
            </xpath>
            <xpath expr="/form/group/group[@name='group3']" position="after">
                <!-- <group colspan="4" > -->
                    <notebook>
                        <page string="Payment Deduction" invisible="payment_difference_handling != 'reconcile_multi_deduct'">
                            <group>
                            
                                <field invisible="0" name="deduct_residual"/>
                                <field invisible="1" name="deduct_analytic_distribution"/>
                            </group>
                            <field colspan="2" context="{'default_amount': deduct_residual, 'default_analytic_distribution': deduct_analytic_distribution}" name="deduction_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field column_invisible="1" name="currency_id"/>
                                    <field name="is_open"/>
                                    <field name="account_id" required="is_open == False"/>
                                    <field groups="analytic.group_analytic_accounting" name="analytic_distribution" options="{'product_field': 'product_id', 'account_field': 'account_id', 'business_domain': 'expense'}" widget="analytic_distribution" optional="hide"/>
                                    <field name="name" required="1"/>
                                    <field name="amount" sum="Total Deduction"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Included Tax" invisible="not tax_ids">
                            <field colspan="2" name="included_tax_line_ids" readonly="1" force_save="1">
                                <tree editable="bottom">
                                    <field name="tax_id"/>
                                    <field name="amount" sum="Total Tax"/>
                                    <field name="currency_id" column_invisible="1"/>
                                   
                                </tree>
                            </field>
                        </page>
                    </notebook>
                <!-- </group> -->
            </xpath></field>
    </record>
</odoo>
