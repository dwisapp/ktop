<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_kategori_ter_action" model="ir.actions.act_window">
        <field name="name">Kategori TER</field>
        <field name="res_model">hr.kategori.ter</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new record.
            </p>
        </field>
    </record>

    <record id="hr_kategori_ter_view_tree" model="ir.ui.view">
        <field name="name">hr.kategori.ter.view.tree</field>
        <field name="model">hr.kategori.ter</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name" />
            </tree>
        </field>
    </record>

</odoo>
