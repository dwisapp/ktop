<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_perhitungan_pph_action" model="ir.actions.act_window">
        <field name="name">Perhitungan PPh</field>
        <field name="res_model">hr.perhitungan.pph</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new record.
            </p>
        </field>
    </record>

    <record id="hr_perhitungan_pph_view_tree" model="ir.ui.view">
        <field name="name">hr.perhitungan.pph.view.tree</field>
        <field name="model">hr.perhitungan.pph</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="hr_kategori_ter_id" required="1" options='{"no_create": true}' />
                <field name="amount_min" />
                <field name="amount_max" />
                <field name="tarif" />
            </tree>
        </field>
    </record>

</odoo>
