<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="jasa_erp_sales_order_action" model="ir.actions.act_window">
        <field name="name">Sales Order</field>
        <field name="res_model">jasa.erp.sales.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new sales order.
            </p>
        </field>
    </record>

    <record id="jasa_erp_sales_order_view_tree" model="ir.ui.view">
        <field name="name">jasa.erp.sales.order.view.tree</field>
        <field name="model">jasa.erp.sales.order</field>
        <field name="arch" type="xml">
            <tree string="" create="0" edit="0" delete="0">
                <field name="name" />
                <field name="customer_name" />
                <field name="status" />
            </tree>
        </field>
    </record>

    <record id="jasa_erp_sales_order_view_form" model="ir.ui.view">
        <field name="name">jasa.erp.sales.order.view.form</field>
        <field name="model">jasa.erp.sales.order</field>
        <field name="arch" type="xml">
            <form string="" create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <label for="name" />
                        <h1>
                            <field name="name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="customer_name" />
                            <field name="status" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Delivery Notes">
                            <field name="delivery_note_ids">
                                <tree>
                                    <field name="name" />
                                    <field name="driver_id" />
                                    <field name="fleet_id" />
                                    <field name="jenis_barang" />
                                    <field name="tujuan_bongkar" />
                                    <field name="tempat_muat" />
                                </tree>
                                <form>
                                    <group>
                                        <group>
                                            <field name="name" />
                                            <field name="driver_id" />
                                            <field name="fleet_id" />
                                        </group>
                                        <group>
                                            <field name="jenis_barang" />
                                            <field name="tujuan_bongkar" />
                                            <field name="tempat_muat" />
                                        </group>
                                    </group>
                                    <notebook>
                                        <page name="items" string="Items">
                                            <field name="item_ids">
                                                <tree>
                                                    <field name="item_code" />
                                                    <field name="item_name" />
                                                    <field name="qty" />
                                                    <field name="uom" />
                                                    <field name="rate" />
                                                </tree>
                                            </field>
                                        </page>
                                    </notebook>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
