<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">
    
        
    
        <record id="ir_cron_jasa_erp_get_sales_order" model="ir.cron">
            <field name="name">Get Sales Order</field>
            <field name="model_id" ref="model_jasa_erp_sales_order"/>
            <field name="state">code</field>
            <field name="code">model.get_sales_order_delivery_note()</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall">True</field>
            <field name="active">True</field>
        </record>

        <record id="ir_cron_auth_jasa_erp" model="ir.cron">
            <field name="name">Auth Jasa ERP</field>
            <field name="model_id" ref="model_jasa_erp_sales_order"/>
            <field name="state">code</field>
            <field name="code">model.auth_jasa_erp()</field>
            <field name="interval_number">2</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall">True</field>
            <field name="active">True</field>
        </record>
    </data>
    


</odoo>
