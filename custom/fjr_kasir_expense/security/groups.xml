<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record model="ir.module.category" id="module_category_human_resources_expenses_accounting">
        <field name="sequence">12</field>
        <field name="name">Expenses Accounting</field>
    </record>

    
    <record id="group_hr_expense_accounting_user" model="res.groups">
        <field name="name">Accounting</field>
        <field name="category_id" ref="module_category_human_resources_expenses_accounting"/>
    </record>

    <record id="group_hr_expense_accounting_manager" model="res.groups">
        <field name="name">Accounting Manager</field>
        <field name="category_id" ref="module_category_human_resources_expenses_accounting"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_expense_accounting_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

  

</odoo>
