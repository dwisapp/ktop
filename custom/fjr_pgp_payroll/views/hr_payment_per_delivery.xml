<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_payment_per_delivery_action" model="ir.actions.act_window">
        <field name="name">Payment Per Delivery</field>
        <field name="res_model">hr.payment.per.delivery</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click the Create button to add a new Payment Per Delivery
            </p>
        </field>
    </record>

    <record id="hr_payment_per_delivery_view_tree" model="ir.ui.view">
        <field name="name">hr.payment.per.delivery.view.tree</field>
        <field name="model">hr.payment.per.delivery</field>
        <field name="arch" type="xml">
            <tree string="" editable="bottom">
                <field name="tempat_muat_id"/>
                <field name="tujuan_bongkar_id"/>
                <field name="vehicle_category_id"/>
                <field name="amount"/>
            </tree>
        </field>
    </record>

    <record id="hr_payment_per_delivery_view_search" model="ir.ui.view">
        <field name="name">hr.payment.per.delivery.view.search</field>
        <field name="model">hr.payment.per.delivery</field>
        <field name="arch" type="xml">
            <search string="" >
                <field name="tempat_muat_id"/>
                <field name="tujuan_bongkar_id"/>
                <field name="vehicle_category_id"/>
            </search>
        </field>
    </record>

</odoo>
