<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_asset_create_journal_entry_view_form" model="ir.ui.view">
        <field name="name">account.asset.create.journal.entry.view.form</field>
        <field name="model">account.asset.create.journal.entry</field>
        <field name="arch" type="xml">
            <form string="">
                <field name="asset_ids" readonly="1" colspan="2" nolabel="1">
                    <tree >
                        <field name="name"/>
                        <field name="acquisition_date"/>
                        <field name="original_value" sum="Total Value"/>
                        <field name="acquisition_date" />
                        <field name="currency_id" column_invisible="1"/>
                    </tree>
                </field>
                
                <group>
                    <group>
                        <field name="journal_id" options="{'no_create': True}" />
                        <field name="account_id" options="{'no_create': True}" />
                        <field name="label" />
                        
                    </group>
                    <group>
                        <field name="partner_id" />
                        <field name="date" />
                    </group>
                </group>
                <footer>
                    <button name="action_create_journal_entry" type="object" string="Create Journal Entry" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>                          
            </form>
        </field>
    </record>

</odoo>
