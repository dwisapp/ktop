    <record id="account_move_view_form_inherit" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <group id="header_left_group" position="inside">
                <!-- <field name="invoice_number_custom" invisible="move_type not in ('out_invoice','out_refund')"/> -->
                <field name="kapal_id" invisible="move_type not in ('out_invoice','out_refund')"/>
                <field name="tanggal_mulai_kegiatan" invisible="move_type not in ('out_invoice','out_refund')"/>
                <field name="tanggal_selesai_kegiatan" invisible="move_type not in ('out_invoice','out_refund')"/>
                <field name="term_condition_id" invisible="move_type not in ('out_invoice','out_refund')" options="{'no_create': True, 'no_open': True}"/>
            </group>
            <field name="invoice_user_id" position="after">
                <field name="pic_user_id" required="move_type in ('out_invoice','out_refund')"/>
            </field>
        </field>
    </record>

