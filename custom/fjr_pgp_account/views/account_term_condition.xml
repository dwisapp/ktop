<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_term_condition_action" model="ir.actions.act_window">
        <field name="name">Term &amp; Condition</field>
        <field name="res_model">account.term.condition</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new term &amp; condition
            </p>
        </field>
    </record>

    <record id="account_term_condition_view_tree" model="ir.ui.view">
        <field name="name">account.term.condition.view.tree</field>
        <field name="model">account.term.condition</field>
        <field name="arch" type="xml">
            <tree string="">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="account_term_condition_view_form" model="ir.ui.view">
        <field name="name">account.term.condition.view.form</field>
        <field name="model">account.term.condition</field>
        <field name="arch" type="xml">
            <form string="">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
