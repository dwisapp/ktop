<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_asset_view_form_inherit" model="ir.ui.view">
        <field name="name">account.asset.view.form.inherit</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_form"/>
        <field name="arch" type="xml">
           <header position="inside">
                <button name="action_create_journal_entry" type="object" string="Create Journal Entry" invisible="state == 'cancel'" />
           </header>
        </field>
    </record>

    <record id="account_asset_view_tree_inherit" model="ir.ui.view">
        <field name="name">account.asset.view.tree.inherit</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_tree"/>
        <field name="arch" type="xml">
            <tree position="inside">
                <header>
                    <button name="action_create_journal_entry" type="object" string="Create Journal Entry" />
                </header>
            </tree>
        </field>
    </record>

</odoo>
