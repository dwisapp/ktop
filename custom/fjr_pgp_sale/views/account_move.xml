<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_move_view_form_inherit" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//tree//field[@name='product_uom_id']" position="after">
                <field name="other_quantity" optional="hide" />
                <field name="other_uom_id" optional="hide" options="{'no_create':True}" />
            </xpath>
        </field>
    </record>

</odoo>
