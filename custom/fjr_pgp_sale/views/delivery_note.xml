<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="delivery_note_action" model="ir.actions.act_window">
        <field name="name">Delivery Note</field>
        <field name="res_model">delivery.note</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new delivery note.
            </p>
        </field>
    </record>

    <record id="delivery_note_view_tree" model="ir.ui.view">
        <field name="name">delivery.note.view.tree</field>
        <field name="model">delivery.note</field>
        <field name="arch" type="xml">
            <tree string="">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" />
                    <button name="action_complete" string="Set to Complete" type="object" />
                    <button name="action_change_sale_order" string="Change Sale Order" type="object" groups="fjr_pgp_sale.group_delivery_note_manager" />
                </header>
                <field name="name" optional="show" />
                <field name="partner_id"  optional="show" />
                <field name="transport_receipt_no"  optional="show" />
                <field name="fleet_id"   optional="show" />
                <field name="line_ids"  widget="one2many_list" optional="hide">
                    <tree limit="4">
                        <field name="product_id"  optional="show" />
                        <field name="product_uom_qty"  optional="show" />
                        <field name="product_uom"  optional="show" />
                        <field name="price_unit" optional="hide" />
                    </tree>
                </field>
                <field name="delivery_start_date"  optional="show" />
                <field name="state" widget="badge" decoration-info="state =='to_bill'" decoration-danger="state == 'cancel'" decoration-success="state == 'complete'" optional="show" />
            </tree>
        </field>
    </record>

    <record id="delivery_note_view_form" model="ir.ui.view">
        <field name="name">delivery.note.view.form</field>
        <field name="model">delivery.note</field>
        <field name="arch" type="xml">
            <form string="">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft' or not line_ids"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancel'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancel'"/>
                    <button name="action_complete" string="Set to Complete" type="object" invisible="state != 'to_bill'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,to_bill,complete"/>
                    <button name="action_change_sale_order" string="Change Sale Order" type="object" groups="fjr_pgp_sale.group_delivery_note_manager" />

                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_orders" type="object" class="oe_stat_button" icon="fa-usd" invisible="sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo" string="Sales Order"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group string="Delivery To">
                        <group >
                            <field name="create_date" invisible="1" />
                            <field name="sequence_id" invisible="create_date != False" options="{'no_create': True, 'no_open': True}" />
                            <field name="partner_id" widget="res_partner_many2one" context="{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}"  readonly="state in ['complete','cancel']" />
                        </group>
                        <group>
                            <field name="customer_order_ref"  readonly="state in ['complete','cancel']" />
                            <field name="delivery_start_date"  readonly="state in ['complete','cancel']" />
                            <field name="delivery_finish_date"  readonly="state in ['complete','cancel']" />
                        </group>
                    </group>

                    <notebook>
                        <page name="items" string="Items">
                            <field name="line_ids" readonly="state in ['complete','cancel']">
                                <tree editable="bottom">
                                    <field name="product_id" context="{'default_delivery_note_ok': True}" />
                                    <field name="product_uom_qty" />
                                    <field name="product_uom" />
                                    <field name="other_quantity" optional="hide"  />
                                    <field name="other_uom_id" optional="hide" options="{'no_create':True}"  />
                                    <field name="price_unit" />
                                    <field name="product_uom_category_id" column_invisible="1" />
                                    <field name="sale_line_id" column_invisible="1" />
                                    <field name="no_container" optional="hide" />
                                </tree>
                            </field>
                        </page>
                        <page name="transporter" string="Transporter Info">
                            <group>
                            
                                <group>
                                    <field name="transporter_id" context="{'default_is_transporter': True}" readonly="state in ['complete','cancel']" />
                                    <field name="driver_employee_id" context="{'default_is_driver': True}" readonly="state in ['complete','cancel']" options="{'no_create': True}" />
                                    <!-- <field name="driver_id" context="{'default_is_driver': True}" readonly="state in ['complete','cancel']" options="{'no_create': True}" /> -->

                                    <field name="transport_receipt_no" readonly="state in ['complete','cancel']" />
                                    <field name="fleet_id" readonly="state in ['complete','cancel']" />
                                </group>
                                <group>
                                    <field name="transport_mode" readonly="state in ['complete','cancel']" />
                                    <field name="transport_receipt_date" readonly="state in ['complete','cancel']" />
                                    <field name='distance' readonly="state in ['complete','cancel']" />
                                </group>
                            </group>
                        </page>
                        <page name="timesheet" string="Timesheet Section">
                            <group>
                                <group>
                                    <field name="employee_id" options="{'no_create': True, 'no_open': True}"  readonly="state in ['complete','cancel']" />
                                    <field name="employee_barcode" readonly="state in ['complete','cancel']" />
                                </group>
                                <group>
                                    <field name="unit_type" readonly="state in ['complete','cancel']" />
                                </group>
                            </group>

                        </page>
                        <page name="order_kerja" string="Order Kerja">
                            <group>
                                <group>
                                    <field name="jenis_barang" readonly="state in ['complete','cancel']" />
                                    <field name="tempat_muat_id" readonly="state in ['complete','cancel']" options="{'no_create':True, 'no_open': True}" />
                                    <field name="tempat_muat" readonly="state in ['complete','cancel']" />
                                </group>
                                <group>
                                    <field name="tujuan_bongkar_id" readonly="state in ['complete','cancel']" options="{'no_create':True, 'no_open': True}" />
                                    <field name="tujuan_bongkar" readonly="state in ['complete','cancel']" />
                                </group>
                            </group>
                        </page>
                        <page name="other" string="Other Info">
                            <group>
                                <group>
                                    <field name="origin" readonly="state in ['complete','cancel']" />
                                </group>
                            </group>
                        </page>
                    </notebook>
                    <group string="Internal Notes">
                        <field colspan='2' nolabel="1" name="notes" readonly="state == 'cancel'" />
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="delivery_note_view_search" model="ir.ui.view">
        <field name="name">delivery.note.view.search</field>
        <field name="model">delivery.note</field>
        <field name="arch" type="xml">
            <search string="">
                <field name="name" string="Delivery No." filter_domain="['|', '|','|',('name', 'ilike', self), ('partner_id', 'ilike', self), ('line_ids.product_id', 'ilike', self), ('origin', 'ilike', self)]"/>
                <field name="partner_id" />
                <field name="line_ids" string="Product" />
                <field name="sale_order_ids" string="Sale Order" />

                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="To Bill" name="to_bill" domain="[('state', '=', 'to_bill')]"/>
                <filter string="Complete" name="complete" domain="[('state', '=', 'complete')]"/>

                <group expand="0" string="Group By">
                    <filter string="Delivery Start Date" name="delivery_start_date" context="{'group_by':'delivery_start_date'}"/>
                    <filter string="Delivery Finish Date" name="delivery_finish_date" context="{'group_by':'delivery_finish_date'}"/>
                    <filter string="Sale Order" name="sale_order_ids" context="{'group_by':'sale_order_ids'}"/>
                    <filter string="Driver" name="driver_employee_id" context="{'group_by':'driver_employee_id'}"/>
                    <filter string="Status" name="state" context="{'group_by':'state'}"/>
                    <filter string="Customer" name="partner_id" context="{'group_by':'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
