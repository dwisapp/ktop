<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_tujuan_bongkar_action" model="ir.actions.act_window">
        <field name="name">Tujuan Bongkar</field>
        <field name="res_model">res.tujuan.bongkar</field>
        <field name="view_mode">tree</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Klik tombol New untuk menambahkan Tujuan Bongkar baru
            </p>
        </field>
    </record>

    <record id="res_tujuan_bongkar_view_tree" model="ir.ui.view">
        <field name="name">res.tujuan.bongkar.view.tree</field>
        <field name="model">res.tujuan.bongkar</field>
        <field name="arch" type="xml">
            <tree string="" editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

</odoo>
