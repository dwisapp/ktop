<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_delivery_note1" model="ir.sequence">
        <field name="name">SJ-PGP-YYYY-</field>
        <field name="code">delivery.note</field>
        <field name="prefix">SJ-PGP-%(year)s-</field>
        <field name="padding">5</field>
    </record>

    <record id="seq_delivery_note2" model="ir.sequence">
        <field name="name">MAT-DN-YYYY-</field>
        <field name="code">delivery.note</field>
        <field name="prefix">MAT-DN-%(year)s-</field>
        <field name="padding">5</field>
    </record>

</odoo>
