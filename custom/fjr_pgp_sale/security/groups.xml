<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="category_delivery_note" model="ir.module.category">
        <field name="name">Delivery Note</field>
        <field name="description">Delivery Note</field>
        <field name="parent_id" ref="base.module_category_sales"/>
        <field name="sequence">15</field>
    </record>

    <record id="group_delivery_note" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="category_delivery_note"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_delivery_note_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="category_delivery_note"/>
        <field name="implied_ids" eval="[(4, ref('group_delivery_note'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
