<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_bank_view_tree_inherit" model="ir.ui.view">
        <field name="name">res.bank.view.tree.inherit</field>
        <field name="model">res.bank</field>
        <field name="inherit_id" ref="base.view_res_bank_tree"/>
        <field name="arch" type="xml">
            <field name="country" position="after">
                <field name="xendit_bank_code"/>
                <field name="midtrans_bank_code"/>
            </field>
        </field>
    </record>

    <record id="res_bank_view_form_inherit" model="ir.ui.view">
        <field name="name">res.bank.view.form.inherit</field>
        <field name="model">res.bank</field>
        <field name="inherit_id" ref="base.view_res_bank_form"/>
        <field name="arch" type="xml">
            <field name="bic" position="after">
                <field name="xendit_bank_code"/>
                <field name="midtrans_bank_code"/>
            </field>
        </field>
    </record>

</odoo>
