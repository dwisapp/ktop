<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="wizard_global_reason_view_form" model="ir.ui.view">
        <field name="name">wizard.global.reason.view.form</field>
        <field name="model">wizard.global.reason</field>
        <field name="arch" type="xml">
            <form string="">
                <group>
                    <field name="model" invisible="1" force_save="1" />
                    <field name="res_id" invisible="1" force_save="1"  />
                    <field name="action_name" invisible="1" force_save="1"  />
                    <field name="reason" placeholder="Reason" />
                </group>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" />
                    <button string="Discard"  special="cancel" />
                </footer>
            </form>
        </field>
    </record>

</odoo>
