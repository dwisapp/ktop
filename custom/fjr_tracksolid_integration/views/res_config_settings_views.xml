<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.tracksolid</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Tracksolid Integration" string="Tracksolid" name="tracksolid_integration">
                    <block title="API Connection" name="tracksolid_api_block">
                        <setting string="Server Configuration" help="Define the endpoint for Tracksolid Pro API.">
                            <div class="row mt16">
                                <label for="tracksolid_base_url" class="col-lg-3 o_light_label"/>
                                <field name="tracksolid_base_url" class="col-lg-9"/>
                            </div>
                            <div class="mt16">
                                <button name="action_sync_tracksolid" type="object" string="Test Connection &amp; Sync Now" class="btn-primary" icon="fa-refresh"/>
                            </div>
                        </setting>
                    </block>

                    <block title="Authentication" name="tracksolid_auth_block">
                        <setting string="User Credentials" help="Account used to generate access tokens.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="tracksolid_user_id" class="col-lg-3 o_light_label"/>
                                    <field name="tracksolid_user_id" class="col-lg-9"/>
                                </div>
                                <div class="row mt8">
                                    <label for="tracksolid_password" class="col-lg-3 o_light_label"/>
                                    <field name="tracksolid_password" password="True" class="col-lg-9"/>
                                </div>
                            </div>
                        </setting>

                        <setting string="Target Account (Optional)" help="Sync devices from a specific sub-account only.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="tracksolid_target_user_id" class="col-lg-3 o_light_label"/>
                                    <field name="tracksolid_target_user_id" class="col-lg-9" placeholder="e.g. client_abc_account"/>
                                </div>
                                <div class="text-muted">
                                    If left empty, it will sync devices from the main User ID above.
                                </div>
                            </div>
                        </setting>

                        <setting string="App Credentials" help="Application keys provided by the vendor.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="tracksolid_app_key" class="col-lg-3 o_light_label"/>
                                    <field name="tracksolid_app_key" class="col-lg-9"/>
                                </div>
                                <div class="row mt8">
                                    <label for="tracksolid_app_secret" class="col-lg-3 o_light_label"/>
                                    <field name="tracksolid_app_secret" class="col-lg-9"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
