<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="fjr_tracksolid_integration.FleetMap" owl="1">
        <div class="h-100 w-100 d-flex flex-column o_content">
            <div class="p-3 bg-white border-bottom d-flex justify-content-between align-items-center flex-shrink-0">
               <h3 class="m-0 text-primary">Fleet Live Map</h3>
               <div>
                   <button class="btn btn-primary shadow-sm" t-on-click="fetchVehicles">
                       <i class="fa fa-refresh"/> Refresh
                   </button>
               </div>
            </div>
            <div class="flex-grow-1 position-relative" style="width: 100%; min-height: 85vh; background: #e0e0e0;">
                <div t-ref="mapContainer" style="width: 100%; height: 100%; position: absolute; top: 0; left: 0;"></div>
            </div>
        </div>
    </t>

</templates>
