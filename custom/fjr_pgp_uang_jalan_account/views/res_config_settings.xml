<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="fjr_kasir_uang_jalan.res_config_settings_view_form_inherit"/>
        <field name="arch" type="xml">
            <app position="inside" name="fjr_kasir_uang_jalan">
                <block title="Accounting Configuration" name="Accounting Configuration">
                    <setting string="Journal Uang Jalan" help="Set Journal Uang Jalan" name="journal_uang_jalan_id" >
                        <field name="journal_uang_jalan_id" domain="[('type','in',('bank','cash'))]"/>
                    </setting>
                    <setting string="Account Uang Jalan" help="Set Account Uang Jalan" name="account_uang_jalan_id" >
                        <field name="account_uang_jalan_id"/>
                    </setting>
                </block>
            </app>
        </field>
    </record>

</odoo>
