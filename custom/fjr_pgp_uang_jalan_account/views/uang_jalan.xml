<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="uang_jalan_view_form_inherit" model="ir.ui.view">
        <field name="name">uang.jalan.view.form.inherit</field>
        <field name="model">uang.jalan</field>
        <field name="inherit_id" ref="fjr_kasir_uang_jalan.uang_jalan_view_form"/>
        <field name="arch" type="xml">
            <!-- <header position='inside'>
                <button name="action_manual_send" type="object" string="XX" />
            </header> -->
            <div name="button_box" position="inside">
                <button class="oe_stat_button" name="action_open_journal_entries"
                    type="object" icon="fa-bars"
                    invisible="not move_id">
                <div class="o_stat_info">
                    <field name="move_id" invisible="1"/>
                    <span class="o_stat_text">
                        Journal Entries
                    </span>
                </div>
            </button>
            </div>
        </field>
    </record>

</odoo>
